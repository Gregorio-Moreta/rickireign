# rickireign.com — environment variable template (NAMES ONLY, no real values).
# Copy this file to `.env.local` and fill in real values there. `.env.local` is gitignored.
# Rule: a value gets the NEXT_PUBLIC_ prefix ONLY if it is safe to expose in the browser.
# Everything without the prefix is server-only and must never reach client code.
# See ../rickireign-build-kit/rickireign-kickoff/CREDENTIALS.md for where to obtain each value.

# --- Sanity (public) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# --- Sanity (server-only) ---
SANITY_API_READ_TOKEN=

# --- Brevo (server-only) ---
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_DOI_TEMPLATE_ID=
# Verified Brevo sender address for the transactional contact email (FROM).
# Use a verified rickireign.com sender in production; a verified personal
# address works for dev/testing.
BREVO_SENDER_EMAIL=

# --- Google Analytics (public) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Cloudflare Turnstile ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Calendly (public scheduling link) ---
NEXT_PUBLIC_CALENDLY_URL=

# --- GitHub MCP token (read from your SHELL env, not committed) ---
# Set this in your shell profile: export GITHUB_PERSONAL_ACCESS_TOKEN=...
# Referenced by .mcp.json as ${GITHUB_PERSONAL_ACCESS_TOKEN}. Do NOT put a real value here.
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Sentry (error monitoring; dormant until a DSN is set) ---
# DSN is public by design (it's the ingest endpoint), but it IS what turns
# Sentry on — leave blank in dev. Set in prod env (Vercel + CF Worker).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Build-time ONLY (source-map upload). SECRET — never NEXT_PUBLIC_, never committed.
# Set as a Vercel build env var + a CF Workers-Builds build var.
SENTRY_AUTH_TOKEN=
# Source-map upload target (build-time). Not secret.
SENTRY_ORG=
SENTRY_PROJECT=
